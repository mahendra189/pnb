# ═══════════════════════════════════════════════════════════════════════════════
# PQSS (Quantum-Proof Systems Scanner) — Production Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ──────────────────────────────────────────────────────────────────────
PROJECT_NAME=Quantum-Proof Systems Scanner
PROJECT_VERSION=0.1.0
DEBUG=true

# ── PostgreSQL (for assets, scans, compliance) ───────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pqss
POSTGRES_PASSWORD=pqss_secure_pwd_2026
POSTGRES_DB=pqss_db

# ── Neo4j (for asset topology graph) ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_pwd_2026

# ── Redis (for Celery broker & caching) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── External Scanning APIs (optional) ────────────────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=

# ── Security ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your_super_secret_key_change_in_production_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Scanning Limits ──────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT_SECONDS=300
RATE_LIMIT_PER_MINUTE=60

# ── ML Engine (For AI predictions) ───────────────────────────────────────────────
ML_ENGINE_ENABLED=true
PROPHET_AVAILABLE=true
PYTORCH_AVAILABLE=true

# ── ITSM Backend (ServiceNow for approval gating) ───────────────────────────────
ITSM_BACKEND=mock
SERVICENOW_INSTANCE_URL=
SERVICENOW_USER=
SERVICENOW_PASSWORD=
