# ─────────────────────────────────────────────────────────────────────────────
# .env — local development (NO docker required)
# Copy of backend/.env.example with safe defaults for local testing
# Databases will be skipped in dev_server.py stub mode
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=local_dev_secret_not_for_production
APP_ENV=development

# ── PostgreSQL (not required for dev_server.py stub run) ─────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pqss
POSTGRES_PASSWORD=pqss_local
POSTGRES_DB=pqss_db

# ── Neo4j (not required for dev_server.py stub run) ───────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_local

# ── Redis / Celery (not required for dev_server.py stub run) ──────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── External APIs (leave blank for local dev) ─────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
NVD_API_KEY=

# ── Approval gate ─────────────────────────────────────────────────────────────
APPROVAL_BACKEND=mock

# ── Scan limits ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT_SECONDS=300
RATE_LIMIT_PER_MINUTE=60
